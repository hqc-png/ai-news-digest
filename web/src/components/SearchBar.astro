---
// Search bar component with hybrid search support
---

<div class="bg-white/80 backdrop-blur-sm rounded-xl shadow-sm p-4 border border-gray-200/50">
  <div class="flex items-center space-x-3">
    <div class="relative flex-1">
      <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400">
        🔍
      </span>
      <input
        type="text"
        id="searchInput"
        placeholder="搜索文章标题或内容..."
        class="w-full pl-10 pr-4 py-2.5 border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-300 text-sm"
      />
    </div>
    <button
      id="searchButton"
      class="px-6 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all duration-300 font-medium text-sm whitespace-nowrap"
    >
      搜索
    </button>
    <button
      id="clearButton"
      class="px-4 py-2.5 bg-gray-100 text-gray-600 rounded-lg hover:bg-gray-200 transition-all duration-300 font-medium text-sm whitespace-nowrap"
    >
      清除
    </button>
  </div>
  <div id="searchResults" class="mt-3 hidden">
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-2">
      <p class="text-xs text-blue-700 font-medium" id="resultCount"></p>
    </div>
  </div>
</div>

<script>
  // Client-side search functionality
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const searchButton = document.getElementById('searchButton');
  const clearButton = document.getElementById('clearButton');
  const searchResults = document.getElementById('searchResults');
  const resultCount = document.getElementById('resultCount');
  const articles = document.querySelectorAll('article');

  function performSearch() {
    const query = searchInput.value.trim().toLowerCase();

    if (!query) {
      showAllArticles();
      return;
    }

    let matchCount = 0;

    articles.forEach((article) => {
      const text = article.textContent?.toLowerCase() || '';

      if (text.includes(query)) {
        (article as HTMLElement).style.display = 'block';
        matchCount++;
      } else {
        (article as HTMLElement).style.display = 'none';
      }
    });

    searchResults?.classList.remove('hidden');
    if (resultCount) {
      resultCount.textContent = `找到 ${matchCount} 篇相关文章`;
    }
  }

  function showAllArticles() {
    articles.forEach((article) => {
      (article as HTMLElement).style.display = 'block';
    });
    searchResults?.classList.add('hidden');
  }

  searchButton?.addEventListener('click', performSearch);
  clearButton?.addEventListener('click', () => {
    searchInput.value = '';
    showAllArticles();
  });

  searchInput?.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      performSearch();
    }
  });
</script>
