---
interface Props {
  id: number;
  title: string;
  summary: string;
  source: string;
  date: Date;
  url: string;
}

const { id, title, summary, source, date, url } = Astro.props;

const formatDate = (d: Date) => {
  return new Date(d).toLocaleString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit'
  });
};
---

<article class="group bg-white/80 backdrop-blur-sm rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 p-5 border border-gray-200/50 hover:border-blue-300">
  <div class="flex flex-col space-y-3">
    <!-- 标题 -->
    <h2 class="text-lg md:text-xl font-bold text-gray-900 leading-tight line-clamp-2">
      <a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors duration-300">
        {title}
      </a>
    </h2>

    <!-- 摘要 -->
    <p class="text-gray-600 text-sm leading-relaxed line-clamp-2">
      {summary}
    </p>

    <!-- 底部信息栏 -->
    <div class="flex items-center justify-between pt-3 border-t border-gray-100">
      <div class="flex items-center space-x-4 text-xs text-gray-500">
        <span class="flex items-center space-x-1">
          <span>📰</span>
          <span>{source}</span>
        </span>
        <span class="flex items-center space-x-1">
          <span>🕐</span>
          <span>{formatDate(date)}</span>
        </span>
      </div>
      <a href={url} target="_blank" rel="noopener noreferrer"
         class="text-blue-600 hover:text-blue-700 text-sm font-medium flex items-center space-x-1 group-hover:translate-x-1 transition-transform duration-300">
        <span>查看</span>
        <span>→</span>
      </a>
    </div>
  </div>
</article>
