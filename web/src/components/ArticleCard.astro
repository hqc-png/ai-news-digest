---
interface Props {
  id: number;
  title: string;
  summary: string;
  source: string;
  date: Date;
  url: string;
}

const { id, title, summary, source, date, url } = Astro.props;

const formatDate = (d: Date) => {
  return new Date(d).toLocaleString('zh-CN', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit'
  });
};
---

<article class="group bg-white/80 backdrop-blur-sm rounded-2xl shadow-md hover:shadow-2xl transition-all duration-300 p-6 mb-6 border border-gray-200/50 transform hover:-translate-y-1">
  <div class="flex justify-between items-start mb-4">
    <h2 class="text-xl md:text-2xl font-bold text-gray-900 flex-1 pr-4 leading-tight">
      <a href={url} target="_blank" rel="noopener noreferrer" class="hover:text-blue-600 transition-colors duration-300 inline-flex items-start">
        <span class="mr-2 text-blue-500 group-hover:scale-110 transition-transform duration-300">🔗</span>
        <span>{title}</span>
      </a>
    </h2>
  </div>

  <p class="text-gray-700 mb-5 leading-relaxed text-base">
    {summary}
  </p>

  <div class="flex flex-wrap justify-between items-center gap-3 text-sm">
    <div class="flex flex-wrap gap-4">
      <span class="flex items-center text-gray-600 bg-gray-100 px-3 py-1 rounded-lg">
        <span class="mr-1.5">📰</span>
        <span class="font-medium">{source}</span>
      </span>
      <span class="flex items-center text-gray-600 bg-gray-100 px-3 py-1 rounded-lg">
        <span class="mr-1.5">🕐</span>
        <span class="font-medium">{formatDate(date)}</span>
      </span>
    </div>
    <a href={url} target="_blank" rel="noopener noreferrer"
       class="inline-flex items-center px-4 py-2 bg-gradient-to-r from-blue-600 to-purple-600 text-white rounded-lg hover:shadow-lg transition-all duration-300 font-medium transform hover:scale-105">
      <span>阅读原文</span>
      <span class="ml-1.5 group-hover:translate-x-1 transition-transform duration-300">→</span>
    </a>
  </div>
</article>
