---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { getArticles, getArticleCount, getArticleStats } from '../lib/db';

const { env } = Astro.locals.runtime;

// 获取文章列表
const articles = await getArticles(env.DB, 1, 50);
const totalCount = await getArticleCount(env.DB);
const stats = await getArticleStats(env.DB);

// 计算最新更新时间
const latestDate = articles.length > 0
  ? new Date(articles[0].publishedAt).toLocaleString('zh-CN')
  : 'N/A';
---

<Layout title="AI News Digest - 首页">
  <!-- Hero Section -->
  <div class="mb-12 text-center">
    <h1 class="text-5xl md:text-6xl font-extrabold mb-4">
      <span class="bg-gradient-to-r from-blue-600 via-purple-600 to-pink-600 bg-clip-text text-transparent">
        AI 新闻聚合
      </span>
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto">
      每日自动更新 AI 领域最新资讯，智能生成中文摘要
    </p>
    <div class="mt-6 flex justify-center items-center space-x-4 text-sm text-gray-500">
      <span class="flex items-center space-x-1">
        <span>⚡</span>
        <span>实时更新</span>
      </span>
      <span>•</span>
      <span class="flex items-center space-x-1">
        <span>🤖</span>
        <span>AI 摘要</span>
      </span>
      <span>•</span>
      <span class="flex items-center space-x-1">
        <span>🔍</span>
        <span>全文搜索</span>
      </span>
    </div>
  </div>

  <!-- 统计信息 - 增强版 -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <div class="group bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 text-white transform hover:-translate-y-1">
      <div class="text-4xl font-black mb-2">{totalCount}</div>
      <div class="text-sm font-medium text-blue-100">📚 总文章数</div>
    </div>
    <div class="group bg-gradient-to-br from-green-500 to-emerald-600 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 text-white transform hover:-translate-y-1">
      <div class="text-4xl font-black mb-2">{articles.length}</div>
      <div class="text-sm font-medium text-green-100">👀 当前显示</div>
    </div>
    <div class="group bg-gradient-to-br from-purple-500 to-pink-600 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 text-white transform hover:-translate-y-1">
      <div class="text-4xl font-black mb-2">{stats.length}</div>
      <div class="text-sm font-medium text-purple-100">📰 新闻来源</div>
    </div>
    <div class="group bg-gradient-to-br from-orange-500 to-red-600 rounded-2xl shadow-lg hover:shadow-2xl transition-all duration-300 p-6 text-white transform hover:-translate-y-1">
      <div class="text-sm font-bold mb-1 text-orange-100">🕐 最新更新</div>
      <div class="text-xs font-medium text-orange-50">{latestDate}</div>
    </div>
  </div>

  <!-- 搜索栏 -->
  <SearchBar />

  <!-- 来源统计 - 增强版 -->
  {stats.length > 0 && (
    <div class="bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg p-6 mb-8 border border-gray-200/50">
      <h3 class="font-bold text-gray-900 mb-4 flex items-center text-lg">
        <span class="mr-2">📊</span>
        来源分布
      </h3>
      <div class="flex flex-wrap gap-3">
        {stats.map(stat => (
          <button class="group px-4 py-2 bg-gradient-to-r from-blue-50 to-purple-50 hover:from-blue-100 hover:to-purple-100 text-blue-700 rounded-full text-sm font-medium transition-all duration-300 hover:shadow-md hover:scale-105 border border-blue-200/50">
            <span class="font-semibold">{stat.source}</span>
            <span class="ml-2 px-2 py-0.5 bg-blue-600 text-white rounded-full text-xs font-bold">{stat.count}</span>
          </button>
        ))}
      </div>
    </div>
  )}

  <!-- 文章列表 - 增强版 -->
  <div class="space-y-6" id="articleList">
    {articles.length === 0 ? (
      <div class="text-center py-20 bg-white/80 backdrop-blur-sm rounded-2xl shadow-lg">
        <div class="text-6xl mb-4">📭</div>
        <p class="text-gray-500 text-xl font-medium mb-2">暂无文章数据</p>
        <p class="text-gray-400 text-sm">
          点击顶部"🔄 更新"按钮抓取最新文章
        </p>
      </div>
    ) : (
      articles.map((article, index) => (
        <ArticleCard
          id={index + 1}
          title={article.title}
          summary={article.summary || '暂无摘要'}
          source={article.source}
          date={article.publishedAt}
          url={article.link}
        />
      ))
    )}
  </div>

  <!-- 页脚说明 - 增强版 -->
  {articles.length > 0 && (
    <div class="mt-12 text-center">
      <div class="inline-block bg-gradient-to-r from-blue-50 to-purple-50 rounded-full px-6 py-3 border border-blue-200/50">
        <p class="text-sm text-gray-600">
          <span class="font-semibold text-blue-600">显示最新 {articles.length} 篇文章</span>
          <span class="mx-2">•</span>
          <span>每日自动更新</span>
          <span class="mx-2">•</span>
          <span>保留最近 7 天</span>
        </p>
      </div>
    </div>
  )}
</Layout>
