---
import Layout from '../layouts/Layout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import SearchBar from '../components/SearchBar.astro';
import { getArticles, getArticleCount, getArticleStats } from '../lib/db';

const { env } = Astro.locals.runtime;

// 获取文章列表
const articles = await getArticles(env.DB, 1, 50);
const totalCount = await getArticleCount(env.DB);
const stats = await getArticleStats(env.DB);

// 计算最新更新时间
const latestDate = articles.length > 0
  ? new Date(articles[0].publishedAt).toLocaleString('zh-CN')
  : 'N/A';
---

<Layout title="AI News Digest - 首页">
  <div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-900 mb-2">
      AI 新闻聚合
    </h1>
    <p class="text-gray-600">
      每日自动更新 AI 领域最新资讯，智能生成中文摘要
    </p>
  </div>

  <!-- 统计信息 -->
  <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-white rounded-lg shadow-sm p-4">
      <div class="text-3xl font-bold text-blue-600">{totalCount}</div>
      <div class="text-sm text-gray-600">总文章数</div>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4">
      <div class="text-3xl font-bold text-green-600">{articles.length}</div>
      <div class="text-sm text-gray-600">当前显示</div>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4">
      <div class="text-3xl font-bold text-purple-600">{stats.length}</div>
      <div class="text-sm text-gray-600">新闻来源</div>
    </div>
    <div class="bg-white rounded-lg shadow-sm p-4">
      <div class="text-lg font-semibold text-gray-900">{latestDate}</div>
      <div class="text-sm text-gray-600">最新更新</div>
    </div>
  </div>

  <!-- 搜索栏 -->
  <SearchBar />

  <!-- 来源统计 -->
  {stats.length > 0 && (
    <div class="bg-white rounded-lg shadow-sm p-4 mb-6">
      <h3 class="font-semibold text-gray-900 mb-3">📊 来源分布</h3>
      <div class="flex flex-wrap gap-3">
        {stats.map(stat => (
          <span class="px-3 py-1 bg-blue-50 text-blue-700 rounded-full text-sm">
            {stat.source}: {stat.count}
          </span>
        ))}
      </div>
    </div>
  )}

  <!-- 文章列表 -->
  <div class="space-y-4">
    {articles.length === 0 ? (
      <div class="text-center py-12 bg-white rounded-lg shadow-sm">
        <p class="text-gray-500 text-lg">暂无文章数据</p>
        <p class="text-gray-400 text-sm mt-2">
          点击顶部"更新"按钮抓取最新文章
        </p>
      </div>
    ) : (
      articles.map((article, index) => (
        <ArticleCard
          id={index + 1}
          title={article.title}
          summary={article.summary || '暂无摘要'}
          source={article.source}
          date={article.publishedAt}
          url={article.link}
        />
      ))
    )}
  </div>

  <!-- 页脚说明 -->
  {articles.length > 0 && (
    <div class="mt-8 text-center text-sm text-gray-500">
      <p>显示最新 {articles.length} 篇文章 | 每日自动更新</p>
    </div>
  )}
</Layout>
