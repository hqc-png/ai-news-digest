---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'AI News Digest',
  description = 'Daily AI news aggregator with intelligent summaries'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 min-h-screen">
    <header class="bg-white shadow-sm">
      <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <div class="flex justify-between items-center">
          <a href="/" class="flex items-center space-x-2">
            <span class="text-2xl font-bold text-blue-600">🤖 AI News Digest</span>
          </a>
          <div class="flex space-x-4">
            <a href="/" class="text-gray-700 hover:text-blue-600 transition">首页</a>
            <a href="/api/trigger-cron" class="text-gray-700 hover:text-blue-600 transition">更新</a>
          </div>
        </div>
      </nav>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>

    <footer class="bg-white border-t mt-12">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 text-center text-gray-600">
        <p>Built with Astro + Cloudflare | Powered by AI</p>
      </div>
    </footer>
  </body>
</html>
